# Configuracion opcional para ngrok.
# Este archivo de ejemplo se versiona; el real es ops/tunnel.env (ignorado en Git).

# Token de tu cuenta ngrok (Dashboard > Your Authtoken)
NGROK_AUTHTOKEN=PEGA_AQUI_TU_TOKEN

# Opcional: dominio reservado en ngrok (requiere plan/feature habilitada)
# Ejemplo: mi-api.ngrok.app
NGROK_DOMAIN=

# Opcional: puerto API local de ngrok para descubrir URL publica.
# Si no lo defines, se usa 4040.
NGROK_API_PORT=4040

