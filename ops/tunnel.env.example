# Modo recomendado: named
CF_TUNNEL_MODE=named

# Token del tunnel (Cloudflare Zero Trust > Access > Tunnels > <tu tunnel> > Run tunnel > token)
CF_TUNNEL_TOKEN=PEGA_AQUI_EL_TOKEN

# Hostname publico del tunnel (ejemplo: api.tudominio.com o tunnel.midominio.com)
CF_TUNNEL_PUBLIC_URL=https://api.tudominio.com

